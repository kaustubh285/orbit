{
	"version": "1.0.0",
	"name": "@orbit/orbit-api",
	"type": "module",
	"exports": {
		".": "./src/app.ts"
	},
	"scripts": {
		"dev": "tsx watch src/index.ts",
		"build": "tsc",
		"start": "node dist/index.js",
		"typecheck": "tsc --noEmit",
		"export:spec": "bun scripts/export-spec.ts",
		"db:generate": "tsx node_modules/drizzle-kit/bin.cjs generate --config=drizzle.config.mjs",
		"db:migrate": "tsx node_modules/drizzle-kit/bin.cjs migrate --config=drizzle.config.mjs",
		"db:push": "tsx node_modules/drizzle-kit/bin.cjs push --config=drizzle.config.mjs",
		"db:studio": "tsx node_modules/drizzle-kit/bin.cjs studio --config=drizzle.config.mjs"
	},
	"dependencies": {
		"@hono/node-server": "^1.19.14",
		"@hono/zod-openapi": "^0.19.1",
		"@scalar/hono-api-reference": "^0.10.9",
		"dotenv-expand": "^13.0.0",
		"drizzle-orm": "^0.45.2",
		"drizzle-zod": "^0.8.3",
		"hono": "^4.12.14",
		"hono-pino": "^0.10.3",
		"pg": "^8.13.3",
		"pino": "^10.3.1",
		"pino-pretty": "^13.1.3",
		"stoker": "^2.0.1",
		"zod": "^3.24.1"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.12",
		"@types/node": "^20.11.17",
		"@types/pg": "^8.11.10",
		"drizzle-kit": "^0.30.4",
		"tsx": "^4.7.1",
		"typescript": "^5.8.3"
	}
}
