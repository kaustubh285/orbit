{
	"version": "1.0.0",
	"name": "@orbit/orbit-api",
	"type": "module",
	"exports": {
		".": "./src/app.ts"
	},
	"scripts": {
		"dev": "bun --watch src/index.ts",
		"start": "bun src/index.ts",
		"build": "bun build src/index.ts --outdir dist --target bun",
		"typecheck": "tsc --noEmit",
		"api:spec": "bun scripts/export-spec.ts",
		"spec-client": "bun run api:spec && cd ../client && bun run generate && cd ../orbit-api",
		"db:generate": "bunx drizzle-kit generate --config=drizzle.config.mjs",
		"db:migrate": "bunx drizzle-kit migrate --config=drizzle.config.mjs",
		"db:push": "bunx drizzle-kit push --config=drizzle.config.mjs",
		"db:studio": "bunx drizzle-kit studio --config=drizzle.config.mjs"
	},
	"dependencies": {
		"@hono/zod-openapi": "^0.19.1",
		"@scalar/hono-api-reference": "^0.10.9",
		"dotenv-expand": "^13.0.0",
		"drizzle-orm": "^0.45.2",
		"drizzle-zod": "^0.8.3",
		"hono": "^4.12.14",
		"hono-pino": "^0.10.3",
		"pg": "^8.13.3",
		"pino": "^10.3.1",
		"pino-pretty": "^13.1.3",
		"stoker": "^2.0.1",
		"zod": "^3.24.1"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.12",
		"@types/bun": "^1.1.0",
		"@types/pg": "^8.11.10",
		"drizzle-kit": "^0.30.4",
		"typescript": "^5.8.3"
	}
}
