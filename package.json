{
	"name": "orbit",
	"private": true,
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"export:spec": "bun --cwd packages/orbit-api run export:spec",
		"generate": "bun --cwd packages/client run generate",
		"dev:api": "bun --cwd packages/orbit-api run dev",
		"dev:frontend": "bun --cwd packages/orbit-frontend run dev",
		"build:api": "bun --cwd packages/orbit-api run build",
		"build:client": "bun --cwd packages/client run build",
		"build:frontend": "bun --cwd packages/orbit-frontend run build",
		"typecheck": "bun --cwd packages/orbit-api run typecheck && bun --cwd packages/client run typecheck && bun --cwd packages/orbit-frontend run typecheck"
	}
}
